    {
      "name": "06_Local_only_NonFunctional",
      "item": [
        {
          "name": "Get Health Status SLA",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.environment.get('env') === 'local') {",
                  "    pm.test('Performance - Local latency under 1000ms', function () { pm.expect(pm.response.responseTime).to.be.below(1000); });",
                  "} else {",
                  "    pm.test('Performance - Mock server bypass', function () { pm.expect(true).to.be.true; });",
